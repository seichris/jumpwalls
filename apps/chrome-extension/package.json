{
  "name": "@infofi/chrome-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "echo \"Use pnpm -C apps/chrome-extension build, then load dist as unpacked extension\"",
    "build": "pnpm -C ../../packages/shared build && node ./scripts/build.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@gh-bounties/shared": "workspace:^",
    "viem": "^2.45.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.25",
    "@types/node": "^22.10.7",
    "esbuild": "^0.25.10",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
