{
  "name": "@infofi/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm -C ../../packages/shared build && prisma generate && tsc -p tsconfig.json",
    "test": "rm -f prisma/test.db && DATABASE_URL=file:./prisma/test.db prisma db push --skip-generate && DATABASE_URL=file:./prisma/test.db tsx --test src/*.test.ts",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "format": "prettier -w .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastxyz/sdk": "0.1.3",
    "@infofi/shared": "workspace:^",
    "@mysten/bcs": "^1.8.0",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^1.8.0",
    "@prisma/client": "^6.2.1",
    "bech32": "^2.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "viem": "^2.21.55",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
