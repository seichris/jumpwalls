generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InfoFiRequest {
  id           String   @id @default(cuid())
  requestId    String   @unique
  requester    String
  paymentToken String
  maxAmountWei String
  sourceURI    String
  question     String
  status       String
  hiredOfferId String?

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfoFiOffer {
  id         String   @id @default(cuid())
  offerId    String   @unique
  requestId  String
  consultant String
  amountWei  String
  etaSeconds Int
  proofType  String
  status     String

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfoFiJob {
  id             String   @id @default(cuid())
  jobId          String   @unique
  requestId      String   @unique
  offerId        String   @unique
  requester      String
  consultant     String
  paymentToken   String
  amountWei      String
  remainingWei   String
  digestHash     String?
  metadataURI    String?
  proofTypeOrURI String?
  hiredAt        DateTime
  deliveredAt    DateTime?

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfoFiPayout {
  id          String   @id @default(cuid())
  jobId       String
  token       String
  recipient   String
  amountWei   String
  txHash      String
  logIndex    Int
  blockNumber Int
  createdAt   DateTime @default(now())

  @@unique([txHash, logIndex])
}

model InfoFiRefund {
  id          String   @id @default(cuid())
  jobId       String
  token       String
  funder      String
  amountWei   String
  txHash      String
  logIndex    Int
  blockNumber Int
  createdAt   DateTime @default(now())

  @@unique([txHash, logIndex])
}

model InfoFiRating {
  id          String   @id @default(cuid())
  jobId       String
  rater       String
  rated       String
  stars       Int
  uri         String
  txHash      String
  logIndex    Int
  blockNumber Int
  createdAt   DateTime @default(now())

  @@unique([jobId, rater])
  @@unique([txHash, logIndex])
}

model InfoFiDigest {
  id                   String   @id @default(cuid())
  jobId                String
  sourceURI            String?
  question             String?
  digest               String
  digestHash           String
  metadataURI          String   @unique
  consultantAddress    String
  proof                String?
  citationsJson        String?
  fairUseVerdict       String?
  fairUseRiskLevel     String?
  fairUseScore         Int?
  fairUsePolicyVersion String?
  fairUseReportJson    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([jobId])
}

model IndexerState {
  id              String   @id @default(cuid())
  chainId         Int
  contractAddress String
  lastBlock       Int
  updatedAt       DateTime @updatedAt

  @@unique([chainId, contractAddress])
}
