generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InfoFiRequest {
  id           String   @id @default(cuid())
  requestId    String   @unique
  requester    String
  paymentToken String
  maxAmountWei String
  sourceURI    String
  question     String
  status       String
  hiredOfferId String?

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfoFiOffer {
  id         String   @id @default(cuid())
  offerId    String   @unique
  requestId  String
  consultant String
  amountWei  String
  etaSeconds Int
  proofType  String
  status     String

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfoFiJob {
  id             String   @id @default(cuid())
  jobId          String   @unique
  requestId      String   @unique
  offerId        String   @unique
  requester      String
  consultant     String
  paymentToken   String
  amountWei      String
  remainingWei   String
  digestHash     String?
  metadataURI    String?
  proofTypeOrURI String?
  hiredAt        DateTime
  deliveredAt    DateTime?

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfoFiPayout {
  id          String   @id @default(cuid())
  jobId       String
  token       String
  recipient   String
  amountWei   String
  txHash      String
  logIndex    Int
  blockNumber Int
  createdAt   DateTime @default(now())

  @@unique([txHash, logIndex])
}

model InfoFiRefund {
  id          String   @id @default(cuid())
  jobId       String
  token       String
  funder      String
  amountWei   String
  txHash      String
  logIndex    Int
  blockNumber Int
  createdAt   DateTime @default(now())

  @@unique([txHash, logIndex])
}

model InfoFiRating {
  id          String   @id @default(cuid())
  jobId       String
  rater       String
  rated       String
  stars       Int
  uri         String
  txHash      String
  logIndex    Int
  blockNumber Int
  createdAt   DateTime @default(now())

  @@unique([jobId, rater])
  @@unique([txHash, logIndex])
}

model InfoFiDigest {
  id                   String   @id @default(cuid())
  jobId                String
  sourceURI            String?
  question             String?
  digest               String
  digestHash           String
  metadataURI          String   @unique
  consultantAddress    String
  proof                String?
  citationsJson        String?
  fairUseVerdict       String?
  fairUseRiskLevel     String?
  fairUseScore         Int?
  fairUsePolicyVersion String?
  fairUseReportJson    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([jobId])
}

model InfoFiUserProfile {
  id            String    @id @default(cuid())
  evmAddress    String    @unique
  fastAddress   String?
  fastPublicKey String?
  fastBoundAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([fastAddress])
}

model InfoFiUserAuthChallenge {
  id            String   @id @default(cuid())
  evmAddress    String
  nonce         String   @unique
  purpose       String
  message       String
  fastAddress   String?
  fastPublicKey String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([evmAddress, purpose, expiresAt])
}

model InfoFiUserSession {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  evmAddress  String
  expiresAt   DateTime
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([evmAddress, expiresAt])
}

model InfoFiFastRequest {
  id                   String   @id @default(cuid())
  requestId            String   @unique
  requester            String
  requesterFastAddress String
  paymentToken         String
  maxAmountWei         String
  sourceURI            String
  question             String
  status               String
  hiredOfferId         String?
  fundingTxHash        String
  fundingNonce         Int
  fundingCertificateJson String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([requester, status, updatedAt])
}

model InfoFiFastOffer {
  id                    String   @id @default(cuid())
  offerId               String   @unique
  requestId             String
  consultant            String
  consultantFastAddress String
  amountWei             String
  etaSeconds            Int
  proofType             String
  status                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([requestId, status, updatedAt])
  @@index([consultant, status, updatedAt])
}

model InfoFiFastJob {
  id                    String   @id @default(cuid())
  jobId                 String   @unique
  requestId             String   @unique
  offerId               String   @unique
  requester             String
  requesterFastAddress  String
  consultant            String
  consultantFastAddress String
  paymentToken          String
  amountWei             String
  remainingWei          String
  digestHash            String?
  metadataURI           String?
  proofTypeOrURI        String?
  status                String
  hiredAt               DateTime
  deliveredAt           DateTime?
  closedAt              DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([requester, status, updatedAt])
  @@index([consultant, status, updatedAt])
}

model InfoFiFastTransfer {
  id              String   @id @default(cuid())
  externalRef     String   @unique
  requestId       String?
  jobId           String?
  direction       String
  status          String
  paymentToken    String
  fromAddress     String
  toAddress       String
  amountWei       String
  txHash          String?
  nonce           Int?
  certificateJson String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([requestId, direction, createdAt])
  @@index([jobId, direction, createdAt])
}

model IndexerState {
  id              String   @id @default(cuid())
  chainId         Int
  contractAddress String
  lastBlock       Int
  updatedAt       DateTime @updatedAt

  @@unique([chainId, contractAddress])
}

model InfoFiAgentProfile {
  id          String  @id @default(cuid())
  agentAddress String
  displayName String?
  status      String  @default("ACTIVE")

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentAddress, chainId, contractAddress])
  @@index([status, updatedAt])
}

model InfoFiAgentCapability {
  id               String   @id @default(cuid())
  agentAddress     String
  domain           String
  paymentToken     String
  minAmountWei     String
  maxAmountWei     String
  etaSeconds       Int
  minConfidence    Float    @default(0.65)
  proofTypeDefault String?
  isEnabled        Boolean  @default(true)

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentAddress, domain, paymentToken, chainId, contractAddress])
  @@index([agentAddress, chainId, contractAddress])
  @@index([domain, isEnabled, chainId, contractAddress])
}

model InfoFiAgentHeartbeat {
  id               String   @id @default(cuid())
  agentAddress     String
  domainsLoggedInJson String
  expectedEtaJson  String?
  lastSeenAt       DateTime
  expiresAt        DateTime
  signatureDigest  String
  clientVersion    String?

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())

  @@unique([signatureDigest, chainId, contractAddress])
  @@index([agentAddress, expiresAt, chainId, contractAddress])
  @@index([expiresAt, chainId, contractAddress])
}

model InfoFiAgentDecisionLog {
  id             String   @id @default(cuid())
  agentAddress   String
  requestId      String
  domain         String
  decision       String
  confidence     Float
  reasonCode     String
  reasonDetail   String?
  offerAmountWei String?
  etaSeconds     Int?
  offerId        String?
  txHash         String?

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())

  @@index([agentAddress, createdAt, chainId, contractAddress])
  @@index([requestId, chainId, contractAddress])
  @@index([domain, createdAt, chainId, contractAddress])
}

model InfoFiAgentAuthChallenge {
  id           String   @id @default(cuid())
  agentAddress String
  nonce        String   @unique
  purpose      String
  message      String
  expiresAt    DateTime
  usedAt       DateTime?

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())

  @@index([agentAddress, purpose, expiresAt, chainId, contractAddress])
}

model InfoFiDomainDemandSignal {
  id               String   @id @default(cuid())
  domain           String
  bucketStart      DateTime
  signalCount      Int      @default(0)
  uniqueClientCount Int     @default(0)
  source           String

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domain, bucketStart, source, chainId, contractAddress])
  @@index([bucketStart, source, chainId, contractAddress])
}

model InfoFiDomainDemandSignalClient {
  id           String   @id @default(cuid())
  domain       String
  bucketStart  DateTime
  source       String
  clientIdHash String

  chainId         Int
  contractAddress String

  createdAt DateTime @default(now())

  @@unique([domain, bucketStart, source, clientIdHash, chainId, contractAddress])
  @@index([bucketStart, source, chainId, contractAddress])
}
