# InfoFi v0 (Base Mainnet) - root .env template

# Run API/indexer in InfoFi mode.
CONTRACT_KIND=infofi

# Network
CHAIN_ID=8453
RPC_URL=https://base-mainnet.g.alchemy.com/v2/<your-key>
# Optional: leave RPC_URL empty and provide chain-specific fallbacks.
RPC_URLS_BASE_MAINNET=https://mainnet.base.org,https://base-rpc.publicnode.com

# Deployed InfoFi contract
CONTRACT_ADDRESS=0x<your_infofi_contract_address>

# API runtime
PORT=8787
DATABASE_URL=file:./apps/api/prisma/dev-infofi.db
API_ORIGIN=http://localhost:8787
WEB_ORIGIN=http://localhost:3000
# Fair-use review policy for POST /digests: off | warn | block
FAIR_USE_ENFORCEMENT_MODE=block
# Optional second-pass LLM review (Gemini). Leave GEMINI_API_KEY empty to disable.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_MS=8000
# Optional agent auth/presence tuning
AGENT_CHALLENGE_TTL_SECONDS=300
AGENT_HEARTBEAT_MAX_TTL_SECONDS=900
AGENT_HEARTBEAT_MAX_DOMAINS=100
AGENT_SIGNUP_MAX_CAPABILITIES=250
# Optional endpoint protection tuning
AGENT_CHALLENGE_RATE_LIMIT_PER_MINUTE=30
AGENT_SIGNUP_RATE_LIMIT_PER_HOUR=20
AGENT_HEARTBEAT_RATE_LIMIT_PER_MINUTE=120
AGENT_DECISION_RATE_LIMIT_PER_MINUTE=480
EXT_SIGNAL_RATE_LIMIT_PER_MINUTE=120
EXT_SIGNAL_MAX_BUCKET_AGE_HOURS=168
EXT_SIGNAL_MAX_FUTURE_SKEW_MINUTES=60
# Demand score is redacted publicly until this many unique clients contribute in 24h.
DEMAND_K_ANONYMITY_MIN_CLIENTS=10

# Optional agent worker config
AGENT_MODE=dry-run
AGENT_ONCE=false
AGENT_POLL_MS=15000
AGENT_HEARTBEAT_INTERVAL_MS=60000
AGENT_HEARTBEAT_TTL_SECONDS=120
AGENT_REQUEST_TAKE=200
AGENT_JOBS_TAKE=200
AGENT_DECISION_LOGGING=true
AGENT_AUTO_DELIVER_ENABLED=true
AGENT_PROOF_TYPE_DEFAULT=agent-auto
AGENT_DELIVER_PROOF_TYPE=reputation-only
AGENT_SALT_PREFIX=infofi-agent-worker
AGENT_DIGEST_TEMPLATE=
AGENT_DIGEST_MAX_CHARS=6000
AGENT_SIGNUP_CAPABILITIES_FILE=
AGENT_SIGNUP_DISPLAY_NAME=
AGENT_SIGNUP_STATUS=ACTIVE
AGENT_DEGRADED_FAILURE_THRESHOLD=3
AGENT_DEGRADED_RECOVERY_HEARTBEATS=2
AGENT_DELIVER_MAX_RETRIES=6
AGENT_DELIVER_RETRY_BASE_MS=15000
AGENT_DELIVER_RETRY_MAX_MS=900000

# Needed for deploy and CLI scripts (set your real key locally)
PRIVATE_KEY=0x<your_private_key>

# Optional: faster/safer indexer boot
INDEXER_START_BLOCK=
INDEXER_BACKFILL_BLOCK_CHUNK=10

# Optional (web): Privy funding
NEXT_PUBLIC_PRIVY_ENABLED=false
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_PRIVY_FUNDING_CHAIN_IDS=8453
NEXT_PUBLIC_PRIVY_DEFAULT_FUND_AMOUNT_USD=50
